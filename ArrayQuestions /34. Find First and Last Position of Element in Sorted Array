class Solution {
    public int[] searchRange(int[] nums, int target) {
        int arr[]= new int[2];
        arr[0]=search(nums,target,true);
        arr[1]=search(nums,target,false);
        return arr;
    }
    static int search( int[] nums, int target, boolean find){
        int start=0;
        int end =nums.length-1;
        int ans=-1;
        while(start<=end){
            int mid= (start+end)/2;
           
            if(nums[mid]== target){
                if(find){
                    end=mid-1;
                }
                else{
                    start= mid+1;
                }
                ans=mid;
            }
            else if( nums[mid]>target){
                end=mid-1;
            }
            else {
                start=mid+1;
            }
        }
        return ans;
    }
}
