class Solution {
    public List<List<Integer>> permute(int[] nums) {
        List<List<Integer>>res= new ArrayList<>();
        ans(new ArrayList<>(),nums,res);
        return res;

        
    }
    static void ans(List<Integer> copy, int[] nums,List<List<Integer>>num){
        if(nums.length==0){
            num.add(copy);
            return ;
        }
        int ch = nums[0];
        int n = copy.size();
        for(int i=0;i<=n;i++){
            List<Integer>first= new ArrayList<>(copy.subList(0,i));
            List<Integer>last= new ArrayList<>(copy.subList(i,n));
            first.add(ch);
            first.addAll(last);
            ans(first,Arrays.copyOfRange(nums,1,nums.length),num);
        }

        }
}
