class Solution {
    public static void swap(int[]arr1, int first, int second){
        int temp= arr1[first];
        arr1[first]=arr1[second];
        arr1[second]=temp;
    }
    public static int [] sort(int [] arr){
        int i=0; 
        while(i<arr.length){
            int current= arr[i]-1;
            if(arr[i]>0 && arr[i]<arr.length&& arr[i]!=arr[current]){
                swap(arr, i, current);
            }
            else{
                i++;
            }
        }
        return arr;
    }
    public int firstMissingPositive(int[] nums) {
        int j=0; 
        sort(nums);
        while(j<nums.length){
            if(j!=nums[j]-1){
                return j+1;
            }
            j++;
        }
        return nums.length+1;
    }
}
